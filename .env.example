# 网球 AI 教练系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 阿里云 Dashscope API Key（必需）
# 获取方式：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# 腾讯云 COS 配置（可选，如需使用 COS 存储）
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_BUCKET=tennis-ai-1411340868
COS_REGION=ap-shanghai

# 数据库配置（可选，默认使用本地 SQLite）
DB_PATH=/home/admin/.openclaw/workspace/ai-coach/data/db/app.db

# 日志级别（可选，默认 INFO）
LOG_LEVEL=INFO
