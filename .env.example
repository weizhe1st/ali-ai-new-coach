# 网球 AI 教练系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到 Git（已在.gitignore 中）

# ==================== 模型配置 ====================

# 阿里云 DashScope API Key（必需）
# 获取方式：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# MoonShot API Key（可选）
MOONSHOT_API_KEY=

# 模型名称
VIDEO_MODEL_NAME=qwen-vl-max
TEXT_MODEL_NAME=qwen-max
IMAGE_MODEL_NAME=qwen-vl-max

# 分析后端配置
# legacy - 使用 complete_analysis_service（推荐）
# simple - 使用简化分析
# qwen_vl - 直接使用 Qwen-VL
ANALYSIS_BACKEND=legacy

# 临时 fallback 开关（不推荐开启）
ENABLE_TEMP_QWEN_FALLBACK=false

# ==================== 渠道配置 ====================

# 钉钉配置
DINGTALK_ENABLED=true
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_TOKEN=
DINGTALK_SECRET=

# QQ 配置
QQ_ENABLED=true
QQ_APP_ID=
QQ_BOT_TOKEN=
QQ_SECRET=

# ==================== 路径配置 ====================

# 基础路径（相对于项目根目录）
BASE_DATA_DIR=./data
TASK_DATA_DIR=./data/tasks
LOG_DIR=./logs
TEMP_DIR=./tmp

# 媒体目录
MEDIA_INBOUND_DIR=./media/inbound
REPORTS_DIR=./reports

# 数据库路径
DB_PATH=./data/db/app.db

# 知识库目录
KNOWLEDGE_DIR=./fused_knowledge

# ==================== 运行模式配置 ====================

# 运行环境：dev（开发） | prod（生产）
APP_ENV=dev

# 调试模式：true | false
# 开发环境默认为 true，生产环境默认为 false
DEBUG=true

# 允许临时分析 fallback（不推荐）
ALLOW_TEMP_ANALYSIS_FALLBACK=false

# 详细任务日志
VERBOSE_TASK_LOGGING=true

# ==================== COS 配置 ====================

# 启用 COS 上传
COS_ENABLED=true

# 腾讯云密钥
COS_SECRET_ID=AKIDyour-secret-id-here
COS_SECRET_KEY=your-secret-key-here

# 存储桶配置
COS_BUCKET=tennis-ai-1411340868
COS_REGION=ap-shanghai

# 路径前缀
COS_RAW_PREFIX=raw/
COS_ANALYZED_PREFIX=analyzed/
COS_GOLDEN_PREFIX=golden/
COS_CANDIDATE_PREFIX=candidate_golden/

# ==================== 性能配置 ====================

# 最大视频大小（MB）
MAX_VIDEO_SIZE_MB=50

# 视频分析超时时间（秒）
VIDEO_ANALYSIS_TIMEOUT=120
